# ============================================================
# SINGU CRM — variáveis de ambiente
# ============================================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env (ele está no .gitignore).
#
# Onde achar: Supabase Dashboard → Settings → API
# ============================================================

# URL do projeto Supabase
VITE_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"

# Chave pública (anon / publishable) — pode ir pro frontend
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# Project reference ID (mesmo valor do subdomínio acima)
VITE_SUPABASE_PROJECT_ID="SEU_PROJECT_REF"
