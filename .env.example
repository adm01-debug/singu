# ============================================================
# SINGU CRM — variáveis de ambiente
# ============================================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env (ele está no .gitignore).
#
# Onde achar: Supabase Dashboard → Settings → API
# ============================================================

# ─── FRONTEND (Vite) — vão pro bundle, são públicas ──────────
VITE_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."
VITE_SUPABASE_PROJECT_ID="SEU_PROJECT_REF"

# ─── EDGE FUNCTIONS — cadastrar no Dashboard, não aqui ───────
# Dashboard → Settings → Edge Functions → Secrets
# Estas variáveis só EXISTEM no servidor, NUNCA no bundle.
#
# Webhook secrets (gerar 32+ chars aleatórios):
#   BITRIX24_WEBHOOK_SECRET=...
#   EVOLUTION_WEBHOOK_SECRET=...
#   EVOLUTION_API_SECRET=...
#   LUX_WEBHOOK_SECRET=...
#   CRON_SECRET=...
#
# AI Gateway (Lovable):
#   LOVABLE_API_KEY=...
#
# External database (banco externo de produtos/clientes):
#   EXTERNAL_SUPABASE_URL=https://OUTRO_PROJECT_REF.supabase.co
#   EXTERNAL_SUPABASE_SERVICE_ROLE_KEY=eyJ... (NUNCA expor no front!)
#
# Integrações de IA externas:
#   ELEVENLABS_API_KEY=...
#   FIRECRAWL_API_KEY=...
#   ENRICHLAYER_API_KEY=...
#
# Notificações:
#   N8N_LUX_WEBHOOK_URL=https://n8n.exemplo/webhook/lux
#   VAPID_PRIVATE_KEY=...
#   VAPID_PUBLIC_KEY=...
