# ============================================================================
# SINGU CRM — Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env real.
# ============================================================================

# ----------------------------------------------------------------------------
# 🔑 SUPABASE — Banco de dados e auth
# ----------------------------------------------------------------------------
# Encontre em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
VITE_SUPABASE_PROJECT_ID="seu-projeto"

# ----------------------------------------------------------------------------
# 🛡️ CLOUDFLARE WORKER (opcional, recomendado em produção)
# ----------------------------------------------------------------------------
# Se você quiser usar o rate limiter, aponte pro worker em vez do Supabase direto:
# VITE_SUPABASE_URL="https://api.singu.promobrindes.com.br"

# ----------------------------------------------------------------------------
# 🐛 SENTRY (observabilidade)
# ----------------------------------------------------------------------------
# Crie projeto em https://sentry.io e cole o DSN aqui
VITE_SENTRY_DSN=""
VITE_APP_VERSION="1.0.0"
# Em dev, errors NÃO são enviados ao Sentry. Para forçar:
# VITE_SENTRY_FORCE_SEND="true"

# ----------------------------------------------------------------------------
# 🧪 TESTES (apenas no .env.test)
# ----------------------------------------------------------------------------
# TEST_USER_EMAIL="test@singu.local"
# TEST_USER_PASSWORD="Test@1234567890"

# ============================================================================
# ⚙️ EDGE FUNCTION SECRETS (cadastrar no Supabase Dashboard, NÃO aqui)
# ============================================================================
# As variáveis abaixo NÃO ficam no .env do frontend. Vão em:
# https://supabase.com/dashboard/project/<projeto>/functions/secrets
#
# Lista completa:
# - LOVABLE_API_KEY              ← Lovable AI Gateway
# - BITRIX24_WEBHOOK_SECRET      ← shared secret pro webhook do Bitrix24
# - EVOLUTION_WEBHOOK_SECRET     ← shared secret pro webhook da Evolution API
# - EVOLUTION_API_SECRET         ← shared secret pro endpoint evolution-api
# - LUX_WEBHOOK_SECRET           ← shared secret pro callback do n8n Lux
# - CRON_SECRET                  ← shared secret pros crons
# - N8N_LUX_WEBHOOK_URL          ← URL do workflow n8n do Lux
# - EXTERNAL_SUPABASE_URL        ← URL do banco externo (external-data fn)
# - EXTERNAL_SUPABASE_SERVICE_ROLE_KEY  ← service_role do banco externo
# - FIRECRAWL_API_KEY            ← Firecrawl scraping
# - ENRICHLAYER_API_KEY          ← EnrichLayer LinkedIn
# - ELEVENLABS_API_KEY           ← ElevenLabs voz
# - VAPID_PUBLIC_KEY             ← Web Push
# - VAPID_PRIVATE_KEY            ← Web Push
#
# Geração de secrets aleatórios:
#   openssl rand -base64 32
#   ou
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
